# Quick Boot local Docker Compose defaults.
# Copy to .env before running docker compose if you need to override ports or passwords.

QUICK_BOOT_MYSQL_PORT=3306
QUICK_BOOT_MYSQL_DATABASE=quick_boot
QUICK_BOOT_MYSQL_USERNAME=root
QUICK_BOOT_MYSQL_ROOT_PASSWORD=quick_boot_dev

QUICK_BOOT_REDIS_PORT=6379
